# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/captrack?retryWrites=true&w=majority

# JWT — use a long random string (min 32 chars)
JWT_SECRET=replace-with-a-secure-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# CORS — set to your frontend URL in production
FRONTEND_URL=http://localhost:3000

# Required to register a coordinator account (keep this secret)
INSTITUTION_MASTER_KEY=your-institution-master-key
